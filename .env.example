# ─── Meta WhatsApp Cloud API ───────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=any_random_secret_you_choose   # e.g. visionprint_secret_2026

# ─── Cashfree ───────────────────────────────────────────────────────────────
# Get from: https://merchant.cashfree.com → Developers → API Keys
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=TEST   # Change to PROD when going live

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Firebase Admin ──────────────────────────────────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → downloads a JSON file
# 3. Base64 encode it: cat serviceAccount.json | base64
# 4. Paste the result here (single line, no spaces)
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json_here
FIREBASE_STORAGE_BUCKET=visionprinttt-1fb8a.firebasestorage.app

# ─── App URL (set automatically by Vercel, but needed for payment return URL) ─
VERCEL_URL=https://your-app.vercel.app
